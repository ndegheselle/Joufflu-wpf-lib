<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts"
    xmlns:joufflu="clr-namespace:Joufflu">

    <!--  Lucide icon font (embedded as a WPF Resource). Family name is "lucide".  -->
    <FontFamily x:Key="LucideIconFamily">/Joufflu;component/Assets/Fonts/#lucide</FontFamily>

    <Style x:Key="{x:Type fonts:FontIcon}" TargetType="{x:Type fonts:FontIcon}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="FontFamily" Value="{StaticResource LucideIconFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />

        <Style.Triggers>
            <!--  Honors the inherited ControlProperties.Size (md keeps the default size).  -->
            <Trigger Property="joufflu:ControlProperties.Size" Value="xs">
                <Setter Property="FontSize" Value="10" />
            </Trigger>
            <Trigger Property="joufflu:ControlProperties.Size" Value="sm">
                <Setter Property="FontSize" Value="11" />
            </Trigger>
            <Trigger Property="joufflu:ControlProperties.Size" Value="lg">
                <Setter Property="FontSize" Value="16" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>