                    <Border>
                        <Rectangle
                            Margin="0"
                            SnapsToDevicePixels="True"
                            Stroke="Black"
                            StrokeDashArray="1 2"
                            StrokeThickness="1" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

