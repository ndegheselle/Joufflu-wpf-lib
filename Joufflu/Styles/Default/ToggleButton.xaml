<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu">

    <Style x:Key="{x:Type ToggleButton}" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.BackgroundBrush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}" />
        <Setter Property="BorderThickness" Value="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}" />
        <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightMd}}" />
        <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Sizes.ControlFontSizeMd}}" />
        <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Sizes.ControlPaddingMd}}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border
                        x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">

                        <Border.RenderTransform>
                            <TranslateTransform x:Name="PressTransform" Y="0" />
                        </Border.RenderTransform>

                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="PressTransform"
                                        Storyboard.TargetProperty="Y"
                                        To="2"
                                        Duration="0:0:0.08">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="PressTransform"
                                        Storyboard.TargetProperty="Y"
                                        To="0"
                                        Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="PressTransform"
                                        Storyboard.TargetProperty="Y"
                                        To="0"
                                        Duration="0:0:0.12" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryBrush}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryContentBrush}}" />
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsChecked" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Primary100Brush}}" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>

            <!--  Size variants  -->
            <Trigger Property="joufflu:ControlProperties.Size" Value="xs">
                <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightXs}}" />
                <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Sizes.ControlFontSizeXs}}" />
                <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Sizes.ControlPaddingXs}}" />
            </Trigger>
            <Trigger Property="joufflu:ControlProperties.Size" Value="sm">
                <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightSm}}" />
                <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Sizes.ControlFontSizeSm}}" />
                <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Sizes.ControlPaddingSm}}" />
            </Trigger>
            <Trigger Property="joufflu:ControlProperties.Size" Value="lg">
                <Setter Property="Height" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightLg}}" />
                <Setter Property="FontSize" Value="{DynamicResource {x:Static joufflu:Sizes.ControlFontSizeLg}}" />
                <Setter Property="Padding" Value="{DynamicResource {x:Static joufflu:Sizes.ControlPaddingLg}}" />
            </Trigger>

            <!--  Square (icon toggle button)  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="joufflu:ControlProperties.IsSquare" Value="True" />
                    <Condition Property="joufflu:ControlProperties.Size" Value="xs" />
                </MultiTrigger.Conditions>
                <Setter Property="Width" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightXs}}" />
                <Setter Property="Padding" Value="0" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="joufflu:ControlProperties.IsSquare" Value="True" />
                    <Condition Property="joufflu:ControlProperties.Size" Value="sm" />
                </MultiTrigger.Conditions>
                <Setter Property="Width" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightSm}}" />
                <Setter Property="Padding" Value="0" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="joufflu:ControlProperties.IsSquare" Value="True" />
                    <Condition Property="joufflu:ControlProperties.Size" Value="md" />
                </MultiTrigger.Conditions>
                <Setter Property="Width" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightMd}}" />
                <Setter Property="Padding" Value="0" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="joufflu:ControlProperties.IsSquare" Value="True" />
                    <Condition Property="joufflu:ControlProperties.Size" Value="lg" />
                </MultiTrigger.Conditions>
                <Setter Property="Width" Value="{DynamicResource {x:Static joufflu:Sizes.ControlHeightLg}}" />
                <Setter Property="Padding" Value="0" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <!--
        Named ToggleButton styles use a "Toggle" prefix to avoid colliding with the
        same-named Button styles (ResourceDictionary keys are strings, not type-scoped).
    -->

    <Style
        x:Key="ToggleGhost"
        BasedOn="{StaticResource {x:Type ToggleButton}}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style
        x:Key="TogglePrimary"
        BasedOn="{StaticResource {x:Type ToggleButton}}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.PrimaryBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Primary100Brush}}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Primary100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="ToggleSecondary"
        BasedOn="{StaticResource {x:Type ToggleButton}}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.SecondaryContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.SecondaryBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Secondary100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="ToggleSuccess"
        BasedOn="{StaticResource {x:Type ToggleButton}}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.SuccessContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.SuccessBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Success100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="ToggleDanger"
        BasedOn="{StaticResource {x:Type ToggleButton}}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.DangerContentBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.DangerBrush}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Danger100Brush}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
