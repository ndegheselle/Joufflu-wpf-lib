<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
                    xmlns:joufflu="clr-namespace:Joufflu"
                    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI">

    <Style x:Key="{x:Type Window}" TargetType="Window">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush900}}"/>
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.BackgroundBrush50}}"/>
        <Setter Property="adonisExtensions:CursorSpotlightExtension.RelativeSpotlightSize" Value="{DynamicResource {x:Static joufflu:Dimensions.CursorSpotlightRelativeSize}}"/>
    </Style>

</ResourceDictionary>
