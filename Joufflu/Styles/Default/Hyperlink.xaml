<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
                    xmlns:joufflu="clr-namespace:Joufflu">

    <Style x:Key="{x:Type Hyperlink}" TargetType="Hyperlink">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.AccentBrush}}"/>
        <Setter Property="TextDecorations" Value="None"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="TextDecorations" Value="Underline"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush400}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
