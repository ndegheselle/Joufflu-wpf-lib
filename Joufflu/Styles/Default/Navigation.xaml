<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts"
    xmlns:joufflu="clr-namespace:Joufflu"
    xmlns:nav="clr-namespace:Joufflu.Navigation">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <nav:OverlayActionStyleToStyleConverter x:Key="OverlayActionStyle" />

    <!--  ============================ Toast ============================  -->
    <DataTemplate x:Key="ToastTemplate" DataType="{x:Type nav:ToastInstance}">
        <Border
            x:Name="Card"
            MinWidth="280"
            MaxWidth="380"
            Margin="0,0,0,8"
            Background="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}"
            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
            BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
            CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="Accent"
                    Grid.Column="0"
                    Width="4"
                    Background="{DynamicResource {x:Static joufflu:Brushes.InfoBrush}}"
                    CornerRadius="8,0,0,8" />

                <fonts:FontIcon
                    x:Name="Icon"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Foreground="{DynamicResource {x:Static joufflu:Brushes.InfoBrush}}"
                    Text="{Binding Icon}" />

                <StackPanel
                    Grid.Column="2"
                    Margin="10"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontWeight="Bold"
                        Text="{Binding Title}"
                        TextWrapping="Wrap"
                        Visibility="{Binding HasTitle, Converter={StaticResource BoolToVis}}" />
                    <TextBlock
                        Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                        Text="{Binding Message}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Button
                    Grid.Column="3"
                    Width="24"
                    Height="24"
                    Margin="0,4,4,0"
                    Padding="0"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding CloseCommand}">
                    <fonts:FontIcon FontSize="14" Text="{x:Static fonts:LucideFontIcons.x}" />
                </Button>
            </Grid>
        </Border>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Type}" Value="Success">
                <Setter TargetName="Accent" Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.SuccessBrush}}" />
                <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.SuccessBrush}}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Type}" Value="Warning">
                <Setter TargetName="Accent" Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.WarningBrush}}" />
                <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.WarningBrush}}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Type}" Value="Danger">
                <Setter TargetName="Accent" Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.DangerBrush}}" />
                <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.DangerBrush}}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!--  ============================ Overlay ============================  -->
    <DataTemplate x:Key="OverlayTemplate" DataType="{x:Type nav:OverlayInstance}">
        <Grid>
            <Border Background="#000000" Opacity="0.5">
                <Border.InputBindings>
                    <MouseBinding Command="{Binding ClickAwayCommand}" MouseAction="LeftClick" />
                </Border.InputBindings>
            </Border>

            <Border
                MinWidth="320"
                MaxWidth="640"
                MaxHeight="600"
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource {x:Static joufflu:Brushes.BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="Header" Margin="16,12,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Text="{Binding Options.Title}" />

                        <Button
                            x:Name="CloseButton"
                            Grid.Column="1"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding CloseCommand}">
                            <fonts:FontIcon FontSize="16" Text="{x:Static fonts:LucideFontIcons.x}" />
                        </Button>
                    </Grid>

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="16,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <ContentPresenter Content="{Binding Content}" />
                    </ScrollViewer>

                    <ItemsControl
                        x:Name="Actions"
                        Grid.Row="2"
                        Margin="16,12"
                        HorizontalAlignment="Right"
                        ItemsSource="{Binding Options.Actions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type nav:OverlayAction}">
                                <Button
                                    Margin="8,0,0,0"
                                    Command="{Binding Invoke}"
                                    Content="{Binding Label}"
                                    Style="{Binding Style, Converter={StaticResource OverlayActionStyle}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Options.Title}" Value="" />
                    <Condition Binding="{Binding Options.ShowCloseButton}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="Header" Property="Visibility" Value="Collapsed" />
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding Options.ShowCloseButton}" Value="False">
                <Setter TargetName="CloseButton" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Options.Actions.Count}" Value="0">
                <Setter TargetName="Actions" Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!--  ============================ NavigationContainer ============================  -->
    <Style TargetType="{x:Type nav:NavigationContainer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationContainer}">
                    <Grid Background="{TemplateBinding Background}">
                        <!--  Unique content display  -->
                        <ContentControl Content="{Binding Navigator.CurrentPage, RelativeSource={RelativeSource TemplatedParent}}" />

                        <!--  Modal overlay stack  -->
                        <ItemsControl
                            ItemTemplate="{StaticResource OverlayTemplate}"
                            ItemsSource="{Binding Overlays.Overlays, RelativeSource={RelativeSource TemplatedParent}}"
                            Visibility="{Binding Overlays.HasOverlays, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!--  Toast stack (always on top)  -->
                        <ItemsControl
                            Margin="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            ItemTemplate="{StaticResource ToastTemplate}"
                            ItemsSource="{Binding Toasts.Toasts, RelativeSource={RelativeSource TemplatedParent}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================ NavigationMenu ============================  -->
    <Style TargetType="{x:Type nav:NavigationMenu}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Width" Value="220" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nav:NavigationMenu}">
                    <ControlTemplate.Resources>

                        <DataTemplate DataType="{x:Type nav:NavigationMenuItem}">
                            <Button
                                x:Name="ItemButton"
                                Height="40"
                                Margin="0,2"
                                Padding="8,0"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}"
                                CommandParameter="{Binding}"
                                ToolTip="{Binding Title}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <fonts:FontIcon
                                        Grid.Column="0"
                                        Width="24"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Text="{Binding Icon}" />

                                    <TextBlock
                                        x:Name="ItemTitle"
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding Title}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="ItemButton" Property="Background" Value="{DynamicResource {x:Static joufflu:Brushes.AccentBrush}}" />
                                    <Setter TargetName="ItemButton" Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.AccentContentBrush}}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                                    <Setter TargetName="ItemTitle" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type nav:NavigationMenuTitle}">
                            <Grid Margin="0,12,0,4">
                                <TextBlock
                                    x:Name="TitleText"
                                    Margin="8,0,0,0"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource {x:Static joufflu:Brushes.Foreground100Brush}}"
                                    Text="{Binding Title}" />
                                <Border
                                    x:Name="TitleLine"
                                    Height="1"
                                    Margin="4,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                                    Visibility="Collapsed" />
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType={x:Type nav:NavigationMenu}}}" Value="True">
                                    <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="TitleLine" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>

                    </ControlTemplate.Resources>

                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <DockPanel>
                            <Button
                                x:Name="CollapseButton"
                                Width="32"
                                Height="32"
                                Margin="8"
                                Padding="0"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding ToggleCollapseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                DockPanel.Dock="Top">
                                <fonts:FontIcon
                                    x:Name="CollapseIcon"
                                    FontSize="18"
                                    Text="{x:Static fonts:LucideFontIcons.PanelLeftClose}" />
                            </Button>

                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter Margin="8,0,8,8" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCollapsed" Value="True">
                            <Setter Property="Width" Value="56" />
                            <Setter TargetName="CollapseButton" Property="HorizontalAlignment" Value="Center" />
                            <Setter TargetName="CollapseIcon" Property="Text" Value="{x:Static fonts:LucideFontIcons.PanelLeftOpen}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
