<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu">

    <Color x:Key="{x:Static joufflu:Colors.ForegroundColor}">#000000</Color>
    <Color x:Key="{x:Static joufflu:Colors.Foreground100Color}">#000000</Color>
    <Color x:Key="{x:Static joufflu:Colors.Foreground200Color}">#000000</Color>

    <Color x:Key="{x:Static joufflu:Colors.BorderColor}">#FFFAFAFA</Color>
    <Color x:Key="{x:Static joufflu:Colors.Border100Color}">#FFF4F4F5</Color>
    <Color x:Key="{x:Static joufflu:Colors.Border200Color}">#FFE4E4E7</Color>

    <Color x:Key="{x:Static joufflu:Colors.BackgroundColor}">#FFFAFAFA</Color>
    <Color x:Key="{x:Static joufflu:Colors.Background100Color}">#FFF4F4F5</Color>
    <Color x:Key="{x:Static joufflu:Colors.Background200Color}">#FFE4E4E7</Color>

    <!--  Primary: zinc-900 background, white content  -->
    <Color x:Key="{x:Static joufflu:Colors.PrimaryColor}">#FF18181B</Color>
    <Color x:Key="{x:Static joufflu:Colors.PrimaryContentColor}">#FFFAFAFA</Color>

    <!--  Secondary: zinc-200 background, zinc-800 content  -->
    <Color x:Key="{x:Static joufflu:Colors.SecondaryColor}">#FFE4E4E7</Color>
    <Color x:Key="{x:Static joufflu:Colors.SecondaryContentColor}">#FF27272A</Color>

    <!--  Accent: zinc-200 background, zinc-800 content  -->
    <Color x:Key="{x:Static joufflu:Colors.AccentColor}">#FFE4E4E7</Color>
    <Color x:Key="{x:Static joufflu:Colors.AccentContentColor}">#FF27272A</Color>

    <!--  Success: green-500 / green-950 content  -->
    <Color x:Key="{x:Static joufflu:Colors.SuccessColor}">#FF22C55E</Color>
    <Color x:Key="{x:Static joufflu:Colors.SuccessContentColor}">#FF052E16</Color>

    <!--  Info: blue-500 / blue-950 content  -->
    <Color x:Key="{x:Static joufflu:Colors.InfoColor}">#FF3B82F6</Color>
    <Color x:Key="{x:Static joufflu:Colors.InfoContentColor}">#FF172554</Color>

    <!--  Warning: yellow-500 / yellow-950 content  -->
    <Color x:Key="{x:Static joufflu:Colors.WarningColor}">#FFEAB308</Color>
    <Color x:Key="{x:Static joufflu:Colors.WarningContentColor}">#FF422006</Color>

    <!--  Danger (Destructive): red-900 background, red-200 content  -->
    <Color x:Key="{x:Static joufflu:Colors.DangerColor}">#FF7F1D1D</Color>
    <Color x:Key="{x:Static joufflu:Colors.DangerContentColor}">#FFFECACA</Color>

    <!--  Foreground Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.ForegroundBrush}" Color="{DynamicResource {x:Static joufflu:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Foreground100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Foreground100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Foreground200Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Foreground200Color}}" />

    <!--  Border Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.BorderBrush}" Color="{DynamicResource {x:Static joufflu:Colors.BorderColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Border100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Border100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Border200Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Border200Color}}" />

    <!--  Background Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.BackgroundBrush}" Color="{DynamicResource {x:Static joufflu:Colors.BackgroundColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Background100Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Background100Color}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.Background200Brush}" Color="{DynamicResource {x:Static joufflu:Colors.Background200Color}}" />

    <!--  Semantic Brushes  -->
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.PrimaryBrush}" Color="{DynamicResource {x:Static joufflu:Colors.PrimaryColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.PrimaryContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.PrimaryContentColor}}" />

    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SecondaryBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SecondaryColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SecondaryContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SecondaryContentColor}}" />

    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.AccentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.AccentColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.AccentContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.AccentContentColor}}" />

    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SuccessBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SuccessColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.SuccessContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.SuccessContentColor}}" />

    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.InfoBrush}" Color="{DynamicResource {x:Static joufflu:Colors.InfoColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.InfoContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.InfoContentColor}}" />

    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.WarningBrush}" Color="{DynamicResource {x:Static joufflu:Colors.WarningColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.WarningContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.WarningContentColor}}" />

    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.DangerBrush}" Color="{DynamicResource {x:Static joufflu:Colors.DangerColor}}" />
    <SolidColorBrush x:Key="{x:Static joufflu:Brushes.DangerContentBrush}" Color="{DynamicResource {x:Static joufflu:Colors.DangerContentColor}}" />

</ResourceDictionary>