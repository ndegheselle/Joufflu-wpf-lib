<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Shared.Resources.Fonts"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Joufflu.Shared;component/Styles/NamedStyles/IconButton.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <FontFamily x:Key="Phosphor">/Joufflu.Shared;Component/Resources/Fonts/Phosphor.ttf#Phosphor</FontFamily>

    <Style
        x:Key="{x:Type fonts:Icon}"
        BasedOn="{StaticResource {x:Type TextBlock}}"
        TargetType="{x:Type fonts:Icon}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static joufflu:Brushes.ForegroundBrush}}" />
        <Setter Property="FontFamily" Value="{StaticResource Phosphor}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
</ResourceDictionary>
