<UserControl
    x:Class="Joufflu.Samples.Views.OverlaysView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock
                Margin="0,0,0,16"
                FontSize="22"
                FontWeight="Bold"
                Text="Overlays" />

            <c:CodeExample
                Title="Modal overlays"
                Code="{Binding Code}"
                Description="Overlays are modal content shown above the page. They have a title bar with a close cross, a content area and an optional action bar. Multiple overlays stack.">
                <WrapPanel>
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding OpenSimpleCommand}"
                        Content="Simple" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding OpenConfirmCommand}"
                        Content="Confirm (with actions)"
                        Style="{StaticResource Primary}" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding OpenFormCommand}"
                        Content="Form" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding OpenStackedCommand}"
                        Content="Stacked (×2)" />
                </WrapPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
