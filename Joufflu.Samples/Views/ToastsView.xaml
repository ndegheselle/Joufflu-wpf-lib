<UserControl
    x:Class="Joufflu.Samples.Views.ToastsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock
                Margin="0,0,0,16"
                FontSize="22"
                FontWeight="Bold"
                Text="Toasts" />

            <c:CodeExample
                Title="Toast types"
                Code="{Binding Code}"
                Description="Toasts stack in the top-right corner, always above page content and overlays, and auto-dismiss after a few seconds (unless sticky).">
                <WrapPanel>
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding InfoCommand}"
                        Content="Info" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding SuccessCommand}"
                        Content="Success"
                        Style="{StaticResource Success}" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding WarningCommand}"
                        Content="Warning" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding ErrorCommand}"
                        Content="Error"
                        Style="{StaticResource Danger}" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding StickyCommand}"
                        Content="Sticky" />
                    <Button
                        Margin="0,0,8,8"
                        Command="{Binding StackCommand}"
                        Content="Stack ×3" />
                </WrapPanel>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
