<UserControl
    x:Class="Joufflu.Samples.Views.CustomControlsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:Joufflu.Samples.Controls"
    xmlns:controls="clr-namespace:Joufflu.Controls;assembly=Joufflu"
    xmlns:fonts="clr-namespace:Joufflu.Assets.Fonts;assembly=Joufflu"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:nav="clr-namespace:Joufflu.Navigation;assembly=Joufflu">
    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock
                Margin="0,0,0,16"
                FontSize="22"
                FontWeight="Bold"
                Text="Custom controls" />

            <c:CodeExample
                Title="FontIcon"
                Code="{Binding FontIconCode}"
                Description="A Lucide icon-font glyph. Foreground uses the design-system brushes and the size follows the inherited ControlProperties.Size.">
                <StackPanel>
                    <WrapPanel>
                        <fonts:FontIcon Margin="0,0,12,0" Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon Margin="0,0,12,0" Text="{x:Static fonts:LucideFontIcons.Home}" />
                        <fonts:FontIcon Margin="0,0,12,0" Text="{x:Static fonts:LucideFontIcons.Bell}" />
                        <fonts:FontIcon Margin="0,0,12,0" Text="{x:Static fonts:LucideFontIcons.Settings}" />
                        <fonts:FontIcon Margin="0,0,12,0" Text="{x:Static fonts:LucideFontIcons.Trash2}" />
                    </WrapPanel>

                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="xs"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="sm"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="md"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            joufflu:ControlProperties.Size="lg"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                    </StackPanel>

                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            joufflu:ControlProperties.Size="lg"
                            Foreground="{DynamicResource {x:Static joufflu:Brushes.PrimaryBrush}}"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            joufflu:ControlProperties.Size="lg"
                            Foreground="{DynamicResource {x:Static joufflu:Brushes.SuccessBrush}}"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            joufflu:ControlProperties.Size="lg"
                            Foreground="{DynamicResource {x:Static joufflu:Brushes.WarningBrush}}"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                        <fonts:FontIcon
                            Margin="0,0,12,0"
                            joufflu:ControlProperties.Size="lg"
                            Foreground="{DynamicResource {x:Static joufflu:Brushes.DangerBrush}}"
                            Text="{x:Static fonts:LucideFontIcons.Leaf}" />
                    </StackPanel>
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Badge"
                Code="{Binding BadgeCode}"
                Description="A pill themed from the semantic brushes, sized through ControlProperties.Size.">
                <StackPanel>
                    <WrapPanel>
                        <controls:Badge Margin="0,0,8,8">Default</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Primary">Primary</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Secondary">Secondary</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Accent">Accent</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Success">Success</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Info">Info</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Warning">Warning</controls:Badge>
                        <controls:Badge Margin="0,0,8,8" Variant="Danger">Danger</controls:Badge>
                    </WrapPanel>

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <controls:Badge
                            Margin="0,0,8,0"
                            joufflu:ControlProperties.Size="xs"
                            Variant="Primary">xs</controls:Badge>
                        <controls:Badge
                            Margin="0,0,8,0"
                            joufflu:ControlProperties.Size="sm"
                            Variant="Primary">sm</controls:Badge>
                        <controls:Badge
                            Margin="0,0,8,0"
                            joufflu:ControlProperties.Size="md"
                            Variant="Primary">md</controls:Badge>
                        <controls:Badge
                            Margin="0,0,8,0"
                            joufflu:ControlProperties.Size="lg"
                            Variant="Primary">lg</controls:Badge>
                    </StackPanel>
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Card"
                Code="{Binding CardCode}"
                Description="A surface with an optional header. The header collapses automatically when not set.">
                <WrapPanel>
                    <controls:Card Width="240" Margin="0,0,12,0" Header="Profile">
                        <StackPanel>
                            <TextBlock Text="A titled surface that groups related content." TextWrapping="Wrap" />
                            <controls:Badge
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Variant="Success">
                                Active
                            </controls:Badge>
                        </StackPanel>
                    </controls:Card>

                    <controls:Card Width="240">
                        <TextBlock Text="A card with no header — just a padded, bordered surface." TextWrapping="Wrap" />
                    </controls:Card>
                </WrapPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="Spinner"
                Code="{Binding SpinnerCode}"
                Description="An indeterminate loading indicator. Color comes from Foreground, diameter from ControlProperties.Size.">
                <StackPanel Orientation="Horizontal">
                    <controls:Spinner Margin="0,0,16,0" joufflu:ControlProperties.Size="xs" />
                    <controls:Spinner Margin="0,0,16,0" joufflu:ControlProperties.Size="sm" />
                    <controls:Spinner Margin="0,0,16,0" joufflu:ControlProperties.Size="md" />
                    <controls:Spinner Margin="0,0,16,0" joufflu:ControlProperties.Size="lg" />
                    <controls:Spinner Foreground="{DynamicResource {x:Static joufflu:Brushes.DangerBrush}}" joufflu:ControlProperties.Size="lg" />
                </StackPanel>
            </c:CodeExample>

            <c:CodeExample
                Title="NavigationMenu"
                Code="{Binding MenuCode}"
                Description="The collapsible side menu in isolation, plugged into its own navigator. Use the chevron to collapse it to an icons-only rail.">
                <Border
                    Height="280"
                    BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                    BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                    CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}"
                    SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <nav:NavigationMenu
                            ItemsSource="{Binding MenuItems}"
                            Navigator="{Binding DemoNavigator}" />

                        <ContentControl
                            Grid.Column="1"
                            Margin="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{Binding DemoNavigator.CurrentPage}" />
                    </Grid>
                </Border>
            </c:CodeExample>
        </StackPanel>
    </ScrollViewer>
</UserControl>
