<UserControl
    x:Class="Joufflu.Samples.Views.SampleFormView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MinWidth="320" Margin="0,4,0,8">
        <TextBlock Text="Name" />
        <TextBox Margin="0,4,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        <CheckBox
            Margin="0,12,0,0"
            Content="Subscribe to the newsletter"
            IsChecked="{Binding Subscribe}" />
    </StackPanel>
</UserControl>
