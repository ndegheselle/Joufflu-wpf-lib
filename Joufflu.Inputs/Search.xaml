<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Shared.Resources.Fonts;assembly=Joufflu.Shared"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:local="clr-namespace:Joufflu.Inputs">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Joufflu;component/Styles/Default/TextBox.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Joufflu.Shared;component/Styles/NamedStyles/IconButton.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type local:Search}">
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Search}">
                    <Border
                        Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}"
                        DataContext="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                        <Grid>
                            <TextBlock
                                Name="PlaceholderText"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"
                                Opacity="0.5"
                                Text="Search ..."
                                Visibility="Collapsed" />
                            <ScrollViewer x:Name="PART_ContentHost" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <fonts:Icon
                                    Margin="0,0,4,0"
                                    FontSize="12"
                                    Opacity="0.5"
                                    Text="{x:Static fonts:IconFont.MagnifyingGlass}" />
                                <!--  Clear button  -->
                                <Button
                                    Name="ClearButton"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource IconButtonSmall}">
                                    <fonts:Icon FontSize="10" Text="{x:Static fonts:IconFont.X}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="ClearButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="ClearButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocused" Value="False" />
                                <Condition Property="Text" Value="" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </MultiTrigger.Setters>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
