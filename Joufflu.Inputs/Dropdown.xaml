<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:local="clr-namespace:Joufflu.Inputs">
    <Style TargetType="{x:Type local:Dropdown}">
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Dropdown}">
                    <Grid>
                        <ToggleButton
                            Name="button"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Margin="{TemplateBinding Margin}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Content="{TemplateBinding Header}" />
                        <Popup IsOpen="{Binding IsChecked, ElementName=button}" StaysOpen="False">
                            <Border
                                MinWidth="{Binding ActualWidth, ElementName=button}"
                                Background="{DynamicResource {x:Static joufflu:Brushes.BackgroundBrush}}"
                                BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                                BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                                CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
                                <ContentPresenter />
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
