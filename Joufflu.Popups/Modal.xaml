<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fonts="clr-namespace:Joufflu.Shared.Resources.Fonts;assembly=Joufflu.Shared"
    xmlns:joufflu="clr-namespace:Joufflu;assembly=Joufflu"
    xmlns:local="clr-namespace:Joufflu.Popups">
    <Style TargetType="{x:Type local:Modal}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Modal}">
                    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Modal}}}">
                        <Border Background="{DynamicResource {x:Static joufflu:Brushes.BackgroundBrush}}" Opacity="0.8">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding HideCommand}" MouseAction="LeftClick" />
                            </Border.InputBindings>
                        </Border>
                        <Border
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{DynamicResource {x:Static joufflu:Brushes.BackgroundBrush}}"
                            BorderBrush="{DynamicResource {x:Static joufflu:Brushes.BorderBrush}}"
                            BorderThickness="{DynamicResource {x:Static joufflu:Dimensions.BorderThickness}}"
                            CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto" />
                                    <RowDefinition />
                                    <RowDefinition Height="auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Background="{DynamicResource {x:Static joufflu:Brushes.Background100Brush}}"
                                    CornerRadius="{DynamicResource {x:Static joufflu:Dimensions.CornerRadius}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Items names  -->
                                        <ItemsControl
                                            Margin="6,0"
                                            VerticalAlignment="Center"
                                            ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <fonts:Icon
                                                            x:Name="separator"
                                                            Margin="6,0"
                                                            Text="{x:Static fonts:IconFont.CaretRight}">
                                                            <fonts:Icon.Style>
                                                                <Style BasedOn="{StaticResource {x:Type fonts:Icon}}" TargetType="{x:Type fonts:Icon}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Content.Options.Title, TargetNullValue='', FallbackValue=''}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </fonts:Icon.Style>
                                                        </fonts:Icon>
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontWeight="Bold"
                                                            Text="{Binding Content.Options.Title, FallbackValue=''}" />
                                                    </StackPanel>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource PreviousData}}" Value="{x:Null}">
                                                            <Setter TargetName="separator" Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button
                                            Grid.Column="1"
                                            Width="23"
                                            Height="23"
                                            HorizontalAlignment="Right"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding HideCommand}">
                                            <fonts:Icon FontSize="10" Text="{x:Static fonts:IconFont.X}" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <ContentPresenter Grid.Row="1" />
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
